# Google Cloud Project Configuration
GOOGLE_CLOUD_PROJECT=evidence-freezer-dev
GOOGLE_CLOUD_REGION=us-east4

# Authentication (Do NOT commit real secrets)
PHOENIX_ENABLE_AUTH=true
PHOENIX_SECRET=replace_with_jwt_secret
PHOENIX_DEFAULT_ADMIN_INITIAL_PASSWORD=replace_with_initial_admin_password
PHOENIX_API_KEY=replace_with_system_api_key

# Phoenix Tracing Configuration
PHOENIX_HOST=http://localhost:6006
PHOENIX_COLLECTOR_ENDPOINT=http://localhost:6006/v1/traces
PHOENIX_CLIENT_HEADERS=
PHOENIX_TRACE_FIXTURES_PATH=packages/shared/fixtures

# Target App Settings
ENABLE_TRACING=true
USE_REAL_GEMINI=false
GEMINI_API_KEY=

# Watcher Settings
WATCHER_POLL_INTERVAL_MS=60000

# ADK Analyst Phoenix MCP Toolset
PHOENIX_MCP_URL=http://localhost:8080/mcp
PHOENIX_MCP_AUTH_MODE=none
PHOENIX_MCP_BEARER_TOKEN=
PHOENIX_MCP_AUDIENCE=
PHOENIX_MCP_SERVICE_ACCOUNT=adk-analyst-sa@evidence-freezer-dev.iam.gserviceaccount.com
PHOENIX_MCP_TOOL_FILTER=list-traces,get-trace,get-spans,get-session,get-prompt,draft-prompt-patch
